<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Thème clair (fond blanc) -->
    <style name="Theme.Windriders2.Light" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Thème sombre (fond bleu très foncé) -->
    <style name="Theme.Windriders2.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowBackground">@color/dark_blue</item>
        <item name="android:colorBackground">@color/dark_blue</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Thème par défaut (pointe vers Light) -->
    <style name="Theme.Windriders2" parent="Theme.Windriders2.Light" />

    <!-- Styles autre -->
    <style name="Theme.Windriders2.NoActionBar.Light" parent="Theme.Windriders2.Light" />
    <style name="Theme.Windriders2.NoActionBar.Dark" parent="Theme.Windriders2.Dark" />
    <style name="Theme.Windriders2.NoActionBar" parent="Theme.Windriders2.NoActionBar.Light" />

    <!-- jsp for pity fonctionne stp -->
    <style name="Theme.Windriders2.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.Windriders2.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>